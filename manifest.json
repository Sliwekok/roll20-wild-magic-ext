{
  "name": "roll20 wild magic",
  "description": "Roll dice and get a random wild magic surge effect from the custom list",
  "version": "1.0",
  "manifest_version": 3,

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "assets/logo16.png",
      "32": "assets/logo32.png",
      "48": "assets/logo48.png",
      "128": "assets/logo128.png"
    }
  },

  "icons": {
    "16": "assets/logo16.png",
    "32": "assets/logo32.png",
    "48": "assets/logo48.png",
    "128": "assets/logo128.png"
  },

  "permissions": ["scripting", "activeTab", "storage"],

  "host_permissions": [
    "*://app.roll20.net/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://app.roll20.net/*"],
      "css": ["app/css/app.css"],
      "js": ["app/js/content.js"]
    }
  ],

  "background": {
    "service_worker": "app/js/background.js",
    "type": "module"
  }
}
